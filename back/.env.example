# Database
# DB_PASSWORD : obligatoire en production (NODE_ENV=production). Ne pas utiliser "horse_password".
DB_HOST=localhost
DB_PORT=5432
DB_NAME=equilife_db
DB_USER=horse_user
DB_PASSWORD=change_me

# JWT & Auth (optionnel - par défaut l'app fonctionne sans mot de passe)
# Pour activer l'authentification : AUTH_ENABLED=true + JWT_SECRET + APP_PIN
# AUTH_ENABLED=true
# JWT_SECRET=votre_secret_long_et_aleatoire_min_32_caracteres
# APP_PIN=1234

# Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# CORS (obligatoire en production : origine(s) du frontend, séparées par des virgules)
CORS_ORIGIN=https://votredomaine.com,https://app.votredomaine.com

# Redis (optionnel)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Server
PORT=3001
NODE_ENV=development
