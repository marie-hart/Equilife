# Database
# Fichier optionnel `.env.local` (même dossier) : chargé après `.env` et prioritaire (pratique pour la DB locale).
# En local : DB_HOST / DB_USER / etc.
# Sur Render (ou autre PaaS) : lier la base PostgreSQL et utiliser DATABASE_URL (prioritaire sur DB_*).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
#
# DB_PASSWORD : obligatoire en production si DATABASE_URL n’est pas défini. Ne pas utiliser "horse_password".
DB_HOST=localhost
DB_PORT=5432
DB_NAME=equilife_db
DB_USER=horse_user
DB_PASSWORD=change_me

# JWT & Auth — connexion uniquement par e-mail / mot de passe (bcrypt)
# USER_AUTH_ENABLED=true + JWT_SECRET (obligatoire en production pour l’app)
# Les chevaux et notes rapides sont liés à l’utilisateur connecté.
# USER_AUTH_ENABLED=true
# JWT_SECRET=votre_secret_long_et_aleatoire_min_32_caracteres

# Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# CORS (obligatoire en production : origine(s) du frontend uniquement, séparées par des virgules — pas l’URL de l’API)
# Ex. front app.equilife.ovh, API api.equilife.ovh → CORS = https://app.equilife.ovh (+ localhost en dev)
CORS_ORIGIN=https://equilife.ovh,http://localhost:5173

# Redis
# Docker local : REDIS_HOST=localhost
# Render sans Redis managé : REDIS_ENABLED=false (cache en mémoire, pas de hostname « redis »)
# Render Redis / Upstash : REDIS_URL=redis://... ou rediss://...
# REDIS_ENABLED=false
# REDIS_URL=
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Server
PORT=3001
NODE_ENV=development
# En dev, l’API écoute en HTTP sur PORT (compatible Vite). Pour HTTPS local : DEV_HTTPS=true + localhost-key.pem / localhost.pem dans back/
# DEV_HTTPS=true
